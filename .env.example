# Commonality — environment template.
# Copy to .env and fill in real values. NEVER commit .env.

# --- Server ---
PORT=8080
NODE_ENV=development
# Public base URL of this service (used in OAuth discovery + invite emails)
PUBLIC_BASE_URL=http://localhost:8080
# Comma-separated CORS allowlist (web app origins)
CORS_ALLOWLIST=http://localhost:5173

# --- Auth (Commonality-issued JWT) ---
# Generate with: openssl rand -hex 32
JWT_SECRET=

# --- Clerk (OAuth / identity provider) ---
CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_ISSUER_URL=
# Create a Clerk "OAuth application" (Clerk dashboard → OAuth Applications) with
# redirect URI ${PUBLIC_BASE_URL}/oauth/callback. These delegate sign-in to Clerk.
CLERK_OAUTH_CLIENT_ID=
CLERK_OAUTH_CLIENT_SECRET=

# --- Supabase (Postgres) ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Apify (LinkedIn scrape / employee lookup) ---
# Ported code reads APIFY_API_KEY first, then falls back to APIFY_TOKEN.
APIFY_API_KEY=
APIFY_TOKEN=

# --- Cassidy (profile enrichment) ---
# The Cassidy integration calls a workflow webhook URL (not a bearer API key).
CASSIDY_WEBHOOK_URL=
CASSIDY_API_KEY=
# Set to "true" to log raw Cassidy responses for debugging.
CASSIDY_DEBUG=false

# --- Anthropic (outreach + call-prep generation) ---
# Optional: without it, analysis.ts falls back to templated outreach/call prep.
ANTHROPIC_API_KEY=

# --- Stripe (billing) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO_MONTHLY=

# --- HubSpot (CRM push) ---
HUBSPOT_API_KEY=

# --- Salesforce (CRM push) ---
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=

# --- Resend (invite emails) ---
RESEND_API_KEY=
RESEND_FROM_EMAIL=invites@commonality.co
